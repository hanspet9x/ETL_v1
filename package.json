{
  "name": "tilla_v1",
  "version": "1.0.0",
  "private": true,
  "description": "Tilla monorepo",
  "scripts": {
    "start:pg": "docker compose up -d",
    "start:backend": "pnpm --dir backend dev",
    "start:frontend": "pnpm --dir frontend dev",
    "dev:backend": "pnpm --dir backend dev",
    "dev:frontend": "pnpm --dir frontend dev",
    "build": "pnpm --dir backend build && pnpm --dir frontend build",
    "prisma:generate": "pnpm --dir backend prisma:generate"
  },
  "license": "ISC",
  "packageManager": "pnpm@10.11.0",
  "devDependencies": {
    "tsx": "4.21.0"
  }
}
