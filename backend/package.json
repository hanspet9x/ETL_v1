{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "sh -c 'tsc -w -p tsconfig.json >/tmp/tilla-backend-tsc.log 2>&1 & TSC_PID=$!; trap \"kill $TSC_PID $APP_PID 2>/dev/null\" EXIT INT TERM; LAST=\"\"; while true; do if [ -f dist/src/main.js ]; then NEXT=$(stat -f %m dist/src/main.js); if [ \"$NEXT\" != \"$LAST\" ]; then LAST=\"$NEXT\"; kill $APP_PID 2>/dev/null; node dist/src/main.js & APP_PID=$!; fi; fi; sleep 1; done'",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/src/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "postinstall": "prisma generate",
    "run-etl": "tsx ./src/run-etl.ts"
  },
  "dependencies": {
    "@apollo/server": "^5.4.0",
    "@as-integrations/express5": "^1.1.2",
    "@azure/storage-blob": "^12.31.0",
    "@nestjs/apollo": "^13.2.4",
    "@nestjs/common": "11.1.17",
    "@nestjs/config": "4.0.3",
    "@nestjs/core": "11.1.17",
    "@nestjs/graphql": "^13.2.4",
    "@nestjs/platform-express": "11.1.17",
    "@prisma/adapter-pg": "7.5.0",
    "@prisma/client": "7.5.0",
    "dotenv": "17.3.1",
    "graphql": "^16.13.1",
    "pg": "8.20.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "prisma": "7.5.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
